@model Decimal
@{
    //number of decimal places - defaults to 4, can be overridden via asp-decimals on nop-editor (e.g. 0 for AMD prices)
    var decimals = 4;
    if (ViewData.ContainsKey("decimals") && ViewData["decimals"] != null
        && int.TryParse(ViewData["decimals"].ToString(), out var parsedDecimals) && parsedDecimals >= 0)
    {
        decimals = parsedDecimals;
    }

    var postfix = "";
    if (ViewData.ContainsKey("postfix") && ViewData["postfix"] != null)
    {
        postfix = ViewData["postfix"].ToString();
    }

    var inputFormat = "{0:F" + decimals + "}";
    var kendoFormat = decimals > 0 ? "#." + new string('0', decimals) : "#";
}
<input asp-for="@Model" asp-format="@inputFormat" />
<script>
    $(document).ready(function () {
    $("#@Html.IdForModel()").kendoNumericTextBox({
        min: @Html.Raw(decimal.MinValue),
        max: @Html.Raw(decimal.MaxValue),
        decimals: @decimals,
        restrictDecimals: true,
        format: "@kendoFormat @postfix"
        });
    });
</script>
